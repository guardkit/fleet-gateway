# Fleet Gateway — Reachy Mini Environment
# Copy to the reachy_mini_conversation_app directory as .env

# Voice/LLM backend (huggingface = free, no API key needed)
BACKEND_PROVIDER=huggingface

# Profile selection
REACHY_MINI_CUSTOM_PROFILE=scholar

# External profiles and tools from fleet-gateway
# UPDATE THESE PATHS to match your local checkout
REACHY_MINI_EXTERNAL_PROFILES_DIRECTORY=/Users/richardwoollcott/Projects/appmilla_github/fleet-gateway/reachy/external_content/external_profiles
REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY=/Users/richardwoollcott/Projects/appmilla_github/fleet-gateway/reachy/external_content/external_tools

# NATS connection to Jarvis on GB10 (via Tailscale)
# Format: nats://user:password@hostname:port
NATS_URL=nats://rich:YOUR_PASSWORD_HERE@promaxgb10-41b1:4222

# study-tutor HTTP adapter — ask_tutor + query_student_model read (FEAT-VOICE-004)
# Same binding the Flutter app consumes; student_id is derived server-side from
# the bearer token, giving the robot identical session semantics to the phone
# (D8 cross-device pickup). The token maps to a student via the adapter's
# STUDY_TUTOR_HTTP_TOKENS table. Defaults: http://promaxgb10-41b1:8100 + empty
# token (empty degrades gracefully to "tutor unavailable" rather than mis-writing).
STUDY_TUTOR_HTTP_URL=http://promaxgb10-41b1:8100
STUDY_TUTOR_TOKEN=token-lilymay

# HuggingFace token (optional, for gated models)
# HF_TOKEN=

# Voice: pin Ryan app-side for the local s2s unit (server flag is unreliable — W0-R).
# MODEL_VOICE=Ryan

# Voice override for HF backend (optional)
# Supported: Aiden, Ryan, Dylan, Eric, Ono_Anna, Serena, Sohee, Uncle_Fu, Vivian
# MODEL_VOICE=Aiden
